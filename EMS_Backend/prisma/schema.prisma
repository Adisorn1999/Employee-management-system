generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────
// ENUMS
// ─────────────────────────────────────

enum Role {
  ADMIN
  STAFF
  USER
}

enum ShiftType {
  MORNING
  NIGHT
}

enum PayrollItemType {
  INCOME
  DEDUCTION
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
  HALF_DAY
  OVERTIME
}

enum ShiftScheduleDayType {
  WORKDAY
  OFF
  MONTHLY_OFF
  EXTRA_OFF
  SPECIAL_OFF
  HOLIDAY
  LEAVE
  ROTATION_OFF
}

enum ShiftScheduleSource {
  DEFAULT_SHIFT
  MANUAL
  MONTHLY_PLAN
  SHIFT_CHANGE
  EMERGENCY_OVERRIDE
}

enum HolidayType {
  COMPANY
  PUBLIC
  SPECIAL
}

enum LeaveType {
  SICK
  PERSONAL
  VACATION
  UNPAID
  OTHER
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum OffDayType {
  MONTHLY_OFF
  EXTRA_OFF
  ROTATION_OFF
  SPECIAL_OFF
}

enum OffDayStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum FinanceAccountCategory {
  PERSONAL_BANK
  CORPORATE_BANK
  WALLET
  GATEWAY
}

enum FinanceAccountStatus {
  ACTIVE
  INACTIVE
  EXPIRED
  SUSPENDED
}

enum FinanceFieldType {
  text
  textarea
  number
  date
  select
  email
  phone
  password
}

// ─────────────────────────────────────
// USER
// ─────────────────────────────────────

model User {
  id           String  @id @default(uuid())
  username     String  @unique
  passwordHash String
  name         String?
  role         Role    @default(USER)
  authRoleId   String? @map("role_id")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions      Session[]
  refreshTokens RefreshToken[]
  authRole      RbacRole?      @relation(fields: [authRoleId], references: [id], onDelete: SetNull)

  schedulesCreated  ShiftSchedule[]    @relation("ScheduleAssignedBy")
  swapHistories     ShiftSwapHistory[] @relation("SwapApprovedBy")
  payrollsProcessed Payroll[]          @relation("PayrollProcessedBy")

  @@index([authRoleId])
}

// ─────────────────────────────────────
// SESSION
// ─────────────────────────────────────

model Session {
  id               String    @id @default(uuid())
  userId           String
  refreshTokenHash String    @unique
  ipAddress        String?
  userAgent        String?
  deviceName       String?
  expiresAt        DateTime
  revokedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model RefreshToken {
  id         String    @id @default(uuid())
  tokenHash  String    @unique
  userId     String
  expiresAt  DateTime
  revokedAt  DateTime?
  replacedBy String?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model RbacRole {
  id          String  @id
  name        String  @unique
  description String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String  @id
  name        String  @unique
  description String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       RbacRole   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

// ─────────────────────────────────────
// EMPLOYEE
// ─────────────────────────────────────

model Employee {
  id String @id @default(uuid())

  prefix     String
  employeeNo String @unique

  name     String
  email    String? @unique
  telegramUsername String?
  phone    String?
  position String?
  departmentId String?
  positionId   String?

  baseSalary    Decimal @default(0) @db.Decimal(10, 2)
  mealAllowance Decimal @default(0) @db.Decimal(10, 2)
  allowance     Decimal @default(0) @db.Decimal(10, 2)

  lateRatePerMin Decimal @default(0) @db.Decimal(10, 2)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schedules      ShiftSchedule[]
  defaultShiftId String?

  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  jobPosition Position?   @relation(fields: [positionId], references: [id], onDelete: SetNull)
  defaultShift Shift?      @relation("EmployeeDefaultShift", fields: [defaultShiftId], references: [id], onDelete: SetNull)

  swapHistoriesFrom ShiftSwapHistory[] @relation("SwapFromEmployee")
  swapHistoriesTo   ShiftSwapHistory[] @relation("SwapToEmployee")

  attendances Attendance[]
  payrolls    Payroll[]
  leaveRequests LeaveRequest[]
  monthlyOffDays MonthlyOffDay[]

  @@index([prefix])
  @@index([departmentId])
  @@index([positionId])
  @@index([defaultShiftId])
}

model FinanceAccount {
  id            String                 @id @default(uuid())
  category      FinanceAccountCategory
  provider      String
  displayName   String
  accountName   String?
  accountNumber String?
  status        FinanceAccountStatus   @default(ACTIVE)
  startDate     DateTime?              @db.Date
  expireDate    DateTime?              @db.Date
  note          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fieldValues FinanceAccountFieldValue[]

  @@index([category])
  @@index([provider])
  @@index([status])
  @@index([expireDate])
  @@map("finance_accounts")
}

model FinanceFieldTemplate {
  id        String                 @id @default(uuid())
  category  FinanceAccountCategory
  provider  String
  name      String
  isActive  Boolean                @default(true)
  createdAt DateTime               @default(now())

  fieldDefinitions FinanceFieldDefinition[]

  @@unique([category, provider, name])
  @@index([category, provider])
  @@index([isActive])
  @@map("finance_field_templates")
}

model FinanceFieldDefinition {
  id          String           @id @default(uuid())
  templateId  String
  fieldKey    String
  labelTh     String
  labelEn     String
  fieldType   FinanceFieldType @default(text)
  placeholder String?
  options     Json?
  isRequired  Boolean          @default(false)
  sortOrder   Int              @default(0)
  isActive    Boolean          @default(true)

  template FinanceFieldTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, fieldKey])
  @@index([templateId])
  @@index([isActive])
  @@map("finance_field_definitions")
}

model FinanceAccountFieldValue {
  id            String @id @default(uuid())
  accountId     String
  fieldKey      String
  labelSnapshot String
  value         String
  sortOrder     Int    @default(0)
  isActive      Boolean @default(true)
  createdAt     DateTime @default(now())

  account FinanceAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([fieldKey])
  @@map("finance_account_field_values")
}

model Department {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  positions Position[]
  employees Employee[]
}

model Position {
  id           String  @id @default(uuid())
  name         String
  description  String?
  departmentId String?
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  employees  Employee[]

  @@unique([name, departmentId])
  @@index([departmentId])
}

// ─────────────────────────────────────
// SHIFT
// ─────────────────────────────────────

model Shift {
  id String @id @default(uuid())

  code      String  @unique
  name      String
  startTime String
  endTime   String
  color     String?
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schedules ShiftSchedule[]
  defaultEmployees Employee[] @relation("EmployeeDefaultShift")

  @@index([isActive])
}

// ─────────────────────────────────────
// SHIFT SCHEDULE
// ─────────────────────────────────────

model ShiftSchedule {
  id String @id @default(uuid())

  employeeId String
  shiftId    String?
  workDate   DateTime @db.Date

  assignedBy String
  note       String?
  dayType    ShiftScheduleDayType @default(WORKDAY)
  source     ShiftScheduleSource  @default(MANUAL)
  reason     String?
  createdBy  String?
  approvedBy String?

  createdAt DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shift    Shift?   @relation(fields: [shiftId], references: [id], onDelete: Restrict)
  assigner User     @relation("ScheduleAssignedBy", fields: [assignedBy], references: [id])

  swapHistories ShiftSwapHistory[]
  attendances   Attendance[]

  @@unique([employeeId, workDate])
  @@index([workDate])
  @@index([employeeId])
  @@index([shiftId])
  @@index([assignedBy])
  @@index([dayType])
  @@index([source])
  @@index([createdBy])
  @@index([approvedBy])
}

// ─────────────────────────────────────
// SHIFT SWAP HISTORY
// ─────────────────────────────────────

model ShiftSwapHistory {
  id String @id @default(uuid())

  fromEmployeeId  String
  toEmployeeId    String
  shiftScheduleId String
  approvedBy      String

  reason String?

  createdAt DateTime @default(now())

  fromEmployee Employee      @relation("SwapFromEmployee", fields: [fromEmployeeId], references: [id])
  toEmployee   Employee      @relation("SwapToEmployee", fields: [toEmployeeId], references: [id])
  schedule     ShiftSchedule @relation(fields: [shiftScheduleId], references: [id], onDelete: Cascade)
  approver     User          @relation("SwapApprovedBy", fields: [approvedBy], references: [id])

  @@index([fromEmployeeId])
  @@index([toEmployeeId])
  @@index([shiftScheduleId])
  @@index([approvedBy])
}

// ─────────────────────────────────────
// ATTENDANCE
// ─────────────────────────────────────

model Attendance {
  id String @id @default(uuid())

  employeeId       String
  shiftScheduleId  String
  checkInAt        DateTime
  checkOutAt       DateTime?
  status           AttendanceStatus @default(PRESENT)
  lateMinutes      Int              @default(0)
  overtimeMinutes  Int              @default(0)
  workMinutes      Int              @default(0)
  note             String?
  manualOverride   Boolean          @default(false)
  updatedBy        String?
  adjustmentReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee      Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shiftSchedule ShiftSchedule @relation(fields: [shiftScheduleId], references: [id], onDelete: Cascade)

  @@unique([shiftScheduleId])
  @@index([employeeId])
  @@index([shiftScheduleId])
  @@index([checkInAt])
  @@index([status])
  @@index([updatedBy])
}

// ─────────────────────────────────────
// HOLIDAY
// ─────────────────────────────────────

model Holiday {
  id String @id @default(uuid())

  name String
  date DateTime @db.Date
  type HolidayType @default(PUBLIC)
  isPaid Boolean @default(true)
  note String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date, name])
  @@index([date])
  @@index([type])
}

model LeaveRequest {
  id String @id @default(uuid())

  employeeId String
  leaveType LeaveType
  startDate DateTime @db.Date
  endDate DateTime @db.Date
  reason String?
  status LeaveStatus @default(PENDING)
  approvedBy String?
  approvedAt DateTime?
  rejectedBy String?
  rejectedAt DateTime?
  rejectReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([startDate, endDate])
  @@index([status])
  @@index([approvedBy])
  @@index([rejectedBy])
}

model MonthlyOffDay {
  id String @id @default(uuid())

  employeeId String
  offDate DateTime @db.Date
  type OffDayType @default(MONTHLY_OFF)
  reason String?
  status OffDayStatus @default(PENDING)
  isOverQuota Boolean @default(false)
  approvedBy String?
  approvedAt DateTime?
  rejectedBy String?
  rejectedAt DateTime?
  rejectReason String?
  createdBy String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([offDate])
  @@index([type])
  @@index([status])
  @@index([createdBy])
  @@index([approvedBy])
}

// ─────────────────────────────────────
// PAYROLL
// ─────────────────────────────────────

model Payroll {
  id String @id @default(uuid())

  employeeId String

  month Int
  year  Int

  totalIncome    Decimal @default(0) @db.Decimal(10, 2)
  totalDeduction Decimal @default(0) @db.Decimal(10, 2)

  netSalary Decimal @default(0) @db.Decimal(10, 2)

  totalAbsent  Int @default(0)
  totalLateMin Int @default(0)

  note String?

  processedBy String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  processor User @relation("PayrollProcessedBy", fields: [processedBy], references: [id])

  items PayrollItem[]

  @@unique([employeeId, month, year])
  @@index([employeeId])
  @@index([month, year])
}

// ─────────────────────────────────────
// PAYROLL ITEM
// ─────────────────────────────────────

model PayrollItem {
  id String @id @default(uuid())

  payrollId String

  type PayrollItemType

  title String

  amount Decimal @db.Decimal(10, 2)

  createdAt DateTime @default(now())

  payroll Payroll @relation(fields: [payrollId], references: [id], onDelete: Cascade)

  @@index([payrollId])
  @@index([type])
}
