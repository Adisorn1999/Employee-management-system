NODE_ENV=development
PORT=3001

# PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/auth_db?schema=public"

# Redis for rate limiting
REDIS_URL="redis://localhost:6379"

# JWT secrets: use long random values in production
JWT_ACCESS_SECRET="dev-access-secret-change-this-to-random-long-value"
JWT_REFRESH_SECRET="dev-refresh-secret-change-this-to-random-long-value"
ACCESS_TOKEN_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="7d"

# Cookie/CORS
CLIENT_ORIGIN="http://localhost:5173"
COOKIE_SECURE=false
